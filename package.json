{
  "name": "rustic-ai-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "concurrently \"npm run watch-lib\" \"ng serve\"",
    "watch-lib": "cd ../libs/ngx-twang-ui-repo && ng build --watch"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "21.1.4",
    "@angular/common": "21.1.4",
    "@angular/core": "21.1.4",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "21.1.4",
    "@angular/platform-browser": "21.1.4",
    "@angular/router": "21.1.4",
    "firebase": "^11.10.0",
    "flowbite": "^4.0.1",
    "lucide-angular": "^0.563.0",
    "ngx-markdown": "^21.1.0",
    "ngx-sse-client": "^20.0.1",
    "ngx-twang-ui": "file:../libs/ngx-twang-ui-repo/dist/ngx-twang-ui",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.1.4",
    "@angular/cli": "21.1.4",
    "@angular/compiler": "21.1.4",
    "@angular/compiler-cli": "21.1.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.24",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "@angular/common": "21.1.4",
    "@angular/core": "21.1.4",
    "@angular/forms": "21.1.4",
    "@angular/router": "21.1.4",
    "@angular/platform-browser": "21.1.4",
    "@angular/platform-browser-dynamic": "21.1.4",
    "@angular/compiler": "21.1.4"
  }
}
